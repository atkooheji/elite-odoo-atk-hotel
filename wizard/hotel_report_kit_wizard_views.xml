<odoo>
    <record id="view_hotel_report_kit_wizard_form" model="ir.ui.view">
        <field name="name">hotel.report.kit.wizard.form</field>
        <field name="model">hotel.report.kit.wizard</field>
        <field name="arch" type="xml">
            <form string="Al Faris Intelligence Kit">
                <sheet>
                    <group>
                        <group>
                            <field name="report_type" />
                            <field name="output_format" />
                        </group>
                        <group>
                            <field name="period_preset" invisible="report_type in ['grc', 'booking_summary', 'room_summary']" />
                            <field name="date_from" invisible="report_type in ['grc', 'booking_summary', 'room_summary']" />
                            <field name="date_to" invisible="report_type in ['grc', 'booking_summary', 'room_summary']" />
                            <field name="booking_id" invisible="report_type not in ['grc', 'booking_summary']" required="report_type in ['grc', 'booking_summary']" />
                            <field name="room_id" invisible="report_type != 'room_summary'" required="report_type == 'room_summary'" />
                        </group>
                    </group>
                    <footer>
                        <button name="action_generate_report" string="Generate Report" type="object" class="btn-primary" />
                        <button string="Cancel" class="btn-secondary" special="cancel" />
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hotel_report_kit_wizard" model="ir.actions.act_window">
        <field name="name">Al Faris Intelligence Kit</field>
        <field name="res_model">hotel.report.kit.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
