<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hotel_transfer_room_wizard_form" model="ir.ui.view">
        <field name="name">hotel.transfer.room.wizard.form</field>
        <field name="model">hotel.transfer.room.wizard</field>
        <field name="arch" type="xml">
            <form string="Transfer Room">
                <group>
                    <field name="booking_id" readonly="1"/>
                    <field name="current_room_id" readonly="1"/>
                    <field name="new_room_id" required="1"/>
                </group>
                <footer>
                    <button name="action_transfer_room" string="Transfer" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hotel_transfer_room_wizard" model="ir.actions.act_window">
        <field name="name">Transfer Room</field>
        <field name="res_model">hotel.transfer.room.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_hotel_transfer_room_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{'default_booking_id': active_id}</field>
    </record>
</odoo>
