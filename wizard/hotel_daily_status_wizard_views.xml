<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hotel_daily_status_wizard_form" model="ir.ui.view">
        <field name="name">hotel.daily.status.wizard.form</field>
        <field name="model">hotel.daily.status.wizard</field>
        <field name="arch" type="xml">
            <form string="Hotel Daily Status">
                <group>
                    <field name="report_date"/>
                </group>
                <footer>
                    <button string="Print PDF" type="object" name="action_print_pdf" class="btn-primary"/>
                    <button string="Print HTML" type="object" name="action_print_html" class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hotel_daily_status_report_wizard" model="ir.actions.act_window">
        <field name="name">Daily Status Report</field>
        <field name="res_model">hotel.daily.status.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_hotel_daily_status_wizard_form"/>
        <field name="target">new</field>
    </record>

</odoo>
