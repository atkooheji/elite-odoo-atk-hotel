                        padding: 3px 10px;
                        border-radius: 4px;
                        font-weight: 600;
                        display: inline-block;
                        margin-bottom: 4px;
                    }

                    /* Section Typography */
                    h2.section-heading {
                        font-size: 11pt;
                        font-weight: 700;
                        color: #2E2E2E;
                        margin-top: 25px;
                        margin-bottom: 12px;
                        border-bottom: 1px solid #D8C7A1; /* Brand Beige */
                        padding-bottom: 3px;
                        text-transform: uppercase;
                        letter-spacing: 0.04em;
                    }

                    /* Tables */
                    table.report-table {
                        width: 100%;
                        border-collapse: collapse;
                        margin-bottom: 25px;
                        font-size: 8.5pt;
                    }
                    table.report-table th, table.report-table td {
                        padding: 8px 10px;
                        text-align: left;
                    }
                    table.report-table th {
                        background-color: #2E2E2E; /* Charcoal */
                        color: #FFFFFF;
                        font-weight: 600;
                        border-bottom: 2px solid #C7A447;
                        text-transform: uppercase;
                        letter-spacing: 0.04em;
                    }
                    table.report-table tr {
                        border-bottom: 1px solid #E2E8F0;
                    }
                    table.report-table tr:nth-child(even) td {
                        background-color: #F7F7F5; /* Zebra striping */
                    }
                    table.report-table td.num, table.report-table th.num {
