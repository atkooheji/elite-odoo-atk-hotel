                    }
                    .total-row {
                        font-weight: 700;
                        background-color: #D8C7A1 !important; /* Gold Tint for totals */
                        color: #2E2E2E;
                    }
                    .grand-total-row {
                        font-weight: 700;
                        background-color: #2E2E2E !important; /* Dark Gold/Charcoal style */
