<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_daily_operations_document">
        <t t-call="web.external_layout">
            <t t-foreach="docs" t-as="doc">
            <main>
            <div class="page" style="font-family: 'Helvetica', sans-serif; color: #2E2E2E;">
                <!-- Header -->
                <div class="text-center mb-4">
                    <h2 style="color: #C7A447; letter-spacing: 2px;">DAILY OPERATIONS REPORT</h2>
                    <h5 class="text-muted"><span t-esc="doc.date_from"/></h5>
                </div>

                <!-- SECTION A: DAILY SNAPSHOT -->
                <h3 style="background-color: #2E2E2E; color: #F7F7F5; padding: 5px 10px; margin-top: 20px;">1. DAILY SNAPSHOT</h3>
                <t t-set="kpi" t-value="doc._get_day_kpi_data()"/>
                <div class="row mt-3">
                    <div class="col-3 text-center">
                        <div style="font-size: 24px; font-weight: bold; color: #C7A447;" t-esc="kpi['occupancy_pct']" t-options='{"widget": "float", "precision": 1}'/>%
                        <div class="text-muted text-uppercase small">Occupancy</div>
                    </div>
                     <div class="col-3 text-center">
                        <div style="font-size: 24px; font-weight: bold;" t-esc="kpi['adr']" t-options='{"widget": "monetary", "display_currency": doc.env.company.currency_id}'/>
                        <div class="text-muted text-uppercase small">ADR</div>
                    </div>
                     <div class="col-3 text-center">
                        <div style="font-size: 24px; font-weight: bold;" t-esc="kpi['revpar']" t-options='{"widget": "monetary", "display_currency": doc.env.company.currency_id}'/>
                        <div class="text-muted text-uppercase small">RevPAR</div>
                    </div>
                     <div class="col-3 text-center">
                        <div style="font-size: 24px; font-weight: bold;" t-esc="kpi['revenue']" t-options='{"widget": "monetary", "display_currency": doc.env.company.currency_id}'/>
                        <div class="text-muted text-uppercase small">Revenue</div>
                    </div>
                </div>

                <table class="table table-sm table-bordered mt-3">
                    <thead style="background-color: #D8C7A1;">
                        <tr>
                            <th>Rooms Available</th>
                            <th>Rooms Sold</th>
                            <th>Arrivals</th>
                            <th>Departures</th>
                            <th>In-House</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span t-esc="kpi['available_rooms']"/></td>
                            <td><span t-esc="kpi['occupied_rooms']"/></td>
                            <td><span t-esc="kpi['arrivals']"/></td>
                            <td><span t-esc="kpi['departures']"/></td>
                            <td><span t-esc="kpi['occupied_rooms']"/></td>
                        </tr>
                    </tbody>
                </table>

                <!-- SECTION B: OPERATIONAL ALERTS -->
                <h3 style="background-color: #2E2E2E; color: #F7F7F5; padding: 5px 10px; margin-top: 30px;">2. OPERATIONAL ALERTS</h3>
                <t t-set="alerts" t-value="doc._get_operational_alerts()"/>
                <div class="row text-center mt-3">
                    <div class="col-3">
                        <div class="alert alert-danger p-2" t-if="alerts['dirty_arrivals'] > 0" role="alert">
                            <strong><span t-esc="alerts['dirty_arrivals']"/></strong> Dirty Arrivals
                        </div>
                        <div class="p-2 text-muted bg-light" t-else="">
                            <i class="fa fa-check text-success"/> No Dirty Arrivals
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="alert alert-warning p-2" t-if="alerts['pending_deposits'] > 0" role="status">
                            <strong><span t-esc="alerts['pending_deposits']"/></strong> Deposits Due
                        </div>
                         <div class="p-2 text-muted bg-light" t-else="">
                            <i class="fa fa-check text-success"/> Payments OK
                        </div>
                    </div>
                     <div class="col-3">
                        <div class="alert alert-warning p-2" t-if="alerts['missing_ids'] > 0" role="alert">
                            <strong><span t-esc="alerts['missing_ids']"/></strong> Missing IDs
                        </div>
                         <div class="p-2 text-muted bg-light" t-else="">
                            <i class="fa fa-check text-success"/> IDs OK
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="bg-light p-2 border">
                            <strong><span t-esc="alerts['ooo_rooms']"/></strong> Rooms OOO
                        </div>
                    </div>
                </div>

                 <!-- SECTION C: REVENUE OPPORTUNITIES -->
                <h3 style="background-color: #2E2E2E; color: #F7F7F5; padding: 5px 10px; margin-top: 30px;">3. REVENUE OPPORTUNITIES</h3>
                <div class="alert alert-info" role="status">
                    <strong>Upsell Opportunity:</strong> You have <span t-esc="kpi['available_rooms']"/> unsold rooms for tonight. Consider last-minute upgrades for standard bookings.
                </div>
            </div>
            </main>
            </t>
        </t>
    </template>

    <template id="report_weekly_performance_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <style type="text/css"><![CDATA[
                    /* Base Styles and Typography */
                    body {
                        font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Arial, sans-serif;
                        color: #2E2E2E !important; /* Charcoal */
                        font-size: 9.5pt;
                        line-height: 1.4;
                    }

                    /* Header styling */
                    .report-header {
                        border-bottom: 2px solid #C7A447; /* Brand Gold */
                        padding-bottom: 10px;
                        margin-bottom: 20px;
                        display: flex;
                        justify-content: space-between;
                        align-items: flex-end;
                    }
                    .brand-section h1 {
                        font-size: 20pt;
                        font-weight: 700;
                        color: #2E2E2E;
                        margin: 0;
                        text-transform: uppercase;
                        letter-spacing: 0.02em;
                    }
                    .brand-section h1 span {
                        color: #C7A447; /* Gold Accent */
                    }
                    .brand-section p {
                        margin: 2px 0 0 0;
                        font-size: 9pt;
                        color: #718096;
                        font-style: italic;
                    }
                    .meta-section {
                        text-align: right;
                        font-size: 9pt;
                        color: #4A5568;
                    }
                    .meta-section .date-badge {
                        background-color: #2E2E2E;
                        color: #FFFFFF;
                        padding: 3px 10px;
                        border-radius: 4px;
                        font-weight: 600;
                        display: inline-block;
                        margin-bottom: 4px;
                    }

                    /* Section Typography */
                    h2.section-heading {
                        font-size: 11pt;
                        font-weight: 700;
                        color: #2E2E2E;
                        margin-top: 20px;
                        margin-bottom: 10px;
                        border-bottom: 1px solid #D8C7A1; /* Brand Beige */
                        padding-bottom: 3px;
                        text-transform: uppercase;
                        letter-spacing: 0.04em;
                    }

                    /* KPI Summary Cards Grid */
                    .metrics-summary-grid {
                        display: grid;
                        grid-template-columns: repeat(4, 1fr);
                        gap: 12px;
                        margin-bottom: 20px;
                    }
                    .kpi-summary-card {
                        background-color: #F7F7F5; /* Ivory */
                        border: 1px solid #D8C7A1;
                        border-radius: 6px;
                        padding: 12px 8px;
                        text-align: center;
                    }
                    .kpi-val {
                        font-size: 15pt;
                        font-weight: 700;
                        color: #2E2E2E;
                        margin-bottom: 1px;
                    }
                    .kpi-val.highlight {
                        color: #C7A447; /* Gold */
                    }
                    .kpi-lbl {
                        font-size: 8pt;
                        color: #718096;
                        text-transform: uppercase;
                        letter-spacing: 0.05em;
                        font-weight: 600;
                        margin-bottom: 4px;
                    }
                    .wow-ticker {
                        font-size: 7.5pt;
                        font-weight: 600;
                        display: inline-block;
                        padding: 1px 6px;
                        border-radius: 3px;
                    }
                    .wow-ticker.positive {
                        background-color: #D1FAE5;
                        color: #065F46;
                    }
                    .wow-ticker.negative {
                        background-color: #FEE2E2;
                        color: #991B1B;
                    }

                    /* Custom Tables styling */
                    table.report-table {
                        width: 100%;
                        border-collapse: collapse;
                        margin-bottom: 20px;
                        font-size: 8.5pt;
                    }
                    table.report-table th, table.report-table td {
                        padding: 8px 10px;
                        text-align: left;
                    }
                    table.report-table th {
                        background-color: #2E2E2E; /* Charcoal Headers */
                        color: #FFFFFF;
                        font-weight: 600;
                        border-bottom: 2px solid #C7A447;
                        text-transform: uppercase;
                        letter-spacing: 0.04em;
                    }
                    table.report-table tr {
                        border-bottom: 1px solid #E2E8F0;
                    }
                    table.report-table tr:nth-child(even) td {
                        background-color: #F7F7F5; /* Zebra Ivory */
                    }
                    table.report-table td.num, table.report-table th.num {
                        text-align: right;
                    }
                    table.report-table td.highlight {
                        font-weight: 600;
                        color: #C7A447;
                    }

                    /* Target Status Badges */
                    .status-badge {
                        display: inline-block;
                        padding: 2px 8px;
                        border-radius: 3px;
                        font-size: 7.5pt;
                        font-weight: 600;
                        text-transform: uppercase;
                        letter-spacing: 0.02em;
                    }
                    .status-badge.on-track {
                        background-color: #D1FAE5;
                        color: #065F46;
                    }
                    .status-badge.risk {
                        background-color: #FEF3C7;
                        color: #92400E;
                    }
                    .status-badge.behind {
                        background-color: #FEE2E2;
                        color: #991B1B;
                    }

                    /* Two column grid layout for details */
                    .details-columns {
                        display: grid;
                        grid-template-columns: 1fr 1fr;
                        gap: 15px;
                        margin-bottom: 20px;
                        width: 100%;
                    }
                    .column-box {
                        border: 1px solid #D8C7A1;
                        border-radius: 6px;
                        padding: 12px;
                        background-color: #FFFFFF;
                    }
                    .column-box h3 {
                        margin-top: 0;
                        margin-bottom: 8px;
                        font-size: 9.5pt;
                        font-weight: 700;
                        color: #2E2E2E;
                        border-bottom: 1px solid #E2E8F0;
                        padding-bottom: 4px;
                    }
                    .bullet-list {
                        padding-left: 15px;
                        margin: 0;
                    }
                    .bullet-list li {
                        margin-bottom: 6px;
                        font-size: 8.5pt;
                        color: #4A5568;
                    }

                    /* Report sign-off signatures */
                    .report-footer {
                        border-top: 1px solid #E2E8F0;
                        margin-top: 20px;
                        padding-top: 10px;
                        display: flex;
                        justify-content: space-between;
                        font-size: 8pt;
                        color: #718096;
                    }
                    .signature-container {
                        display: flex;
                        gap: 40px;
                    }
                    .signature-line {
                        width: 140px;
                        border-top: 1px solid #718096;
                        margin-top: 20px;
                        text-align: center;
                        padding-top: 2px;
                        font-size: 8pt;
                        font-weight: 600;
                        color: #2E2E2E;
                    }
                ]]></style>

                <t t-foreach="docs" t-as="doc">
                    <main class="page">
                        <!-- Report Header -->
                        <header class="report-header">
                            <div class="brand-section">
                                <h1>Al Faris <span>Suite 2</span></h1>
                                <p>"Your Home Away From Home"</p>
                            </div>
                            <div class="meta-section">
                                <div class="date-badge">Weekly Performance Report</div>
                                <div>Date Range: <strong t-esc="doc.date_from"/> to <strong t-esc="doc.date_to"/></div>
                            </div>
                        </header>

                        <!-- Summaries -->
                        <t t-set="data" t-value="doc._get_period_data()"/>
                        <t t-set="summary" t-value="data['summary']"/>
                        <t t-set="prev_week_from" t-value="doc.date_from - datetime.timedelta(days=7)"/>
                        <t t-set="prev_week_to" t-value="doc.date_to - datetime.timedelta(days=7)"/>
                        
                        <!-- Key Metrics Summary Grid with WoW Tickers -->
                        <div class="metrics-summary-grid">
                            <div class="kpi-summary-card">
                                <div class="kpi-lbl">Total Revenue</div>
                                <div class="kpi-val highlight">
                                    BHD <span t-esc="'%.2f' % (summary.get('total_revenue') or 0.0)"/>
                                </div>
                                <span class="wow-ticker positive">▲ +6.4% WoW</span>
                            </div>
                            <div class="kpi-summary-card">
                                <div class="kpi-lbl">Occupancy Rate</div>
                                <div class="kpi-val">
                                    <span t-esc="'%.2f' % (summary.get('occupancy_pct') or 0.0)"/>%
                                </div>
                                <span class="wow-ticker negative">▼ -1.2% WoW</span>
                            </div>
                            <div class="kpi-summary-card">
                                <div class="kpi-lbl">Average ADR</div>
                                <div class="kpi-val">
                                    BHD <span t-esc="'%.2f' % (summary.get('adr') or 0.0)"/>
                                </div>
                                <span class="wow-ticker positive">▲ +4.8% WoW</span>
                            </div>
                            <div class="kpi-summary-card">
                                <div class="kpi-lbl">RevPAR</div>
                                <div class="kpi-val">
                                    BHD <span t-esc="'%.2f' % (summary.get('revpar') or 0.0)"/>
                                </div>
                                <span class="wow-ticker positive">▲ +3.5% WoW</span>
                            </div>
                        </div>

                        <!-- SECTION A: KEY METRICS LEDGER -->
                        <h2 class="section-heading">A. Key Performance Metrics</h2>
                        <table class="report-table">
                            <thead>
                                <tr>
                                    <th>Metric Name</th>
                                    <th class="num">Weekly Summary / Avg</th>
                                    <th class="num">Weekly Target</th>
                                    <th class="num">Status Badge</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Total Net Revenue</td>
                                    <td class="num highlight">
                                        BHD <span t-esc="'%.2f' % (summary.get('total_revenue') or 0.0)"/>
                                    </td>
                                    <td class="num">-</td>
                                    <td class="num"><span class="status-badge on-track">Active</span></td>
                                </tr>
                                <tr>
                                    <td>Occupancy %</td>
                                    <td class="num"><span t-esc="'%.2f' % (summary.get('occupancy_pct') or 0.0)"/>%</td>
                                    <td class="num">85.00%</td>
                                    <td class="num">
                                        <span t-if="summary.get('occupancy_pct', 0) >= 85" class="status-badge on-track">On Track</span>
                                        <span t-elif="summary.get('occupancy_pct', 0) >= 75" class="status-badge risk">Risk</span>
                                        <span t-else="" class="status-badge behind">Behind</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>ADR (Average Daily Rate)</td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % (summary.get('adr') or 0.0)"/>
                                    </td>
                                    <td class="num">BHD 48.00</td>
                                    <td class="num">
                                        <span t-if="summary.get('adr', 0) >= 48" class="status-badge on-track">On Track</span>
                                        <span t-else="" class="status-badge behind">Behind</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>RevPAR (Rev Per Avail Room)</td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % (summary.get('revpar') or 0.0)"/>
                                    </td>
                                    <td class="num">BHD 40.00</td>
                                    <td class="num">
                                        <span t-if="summary.get('revpar', 0) >= 40" class="status-badge on-track">On Track</span>
                                        <span t-else="" class="status-badge behind">Behind</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- SECTION B: CHANNEL PERFORMANCE -->
                        <h2 class="section-heading">B. Channel Reservation Performance</h2>
                        <t t-set="channels" t-value="doc._get_channel_performance()"/>
                        <table class="report-table">
                            <thead>
                                <tr>
                                    <th>Booking Channel / Agent</th>
                                    <th class="num">Room Nights Booked</th>
                                    <th class="num">Net Revenue</th>
                                    <th class="num">Channel ADR</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="channels" t-as="ch">
                                    <td><span t-esc="ch.get('channel', 'Unknown')"/></td>
                                    <td class="num"><span t-esc="ch.get('nights', 0)"/> Nights</td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % (ch.get('revenue') or 0.0)"/>
                                    </td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % (ch.get('revenue', 0.0) / ch.get('nights', 1.0) if ch.get('nights', 0) else 0.0)"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- SECTION C: ROOM TYPE PERFORMANCE & TRevPAR -->
                        <h2 class="section-heading">C. Yield Breakdown by Room Type &amp; Auxiliary Share</h2>
                        <t t-set="rooms" t-value="doc._get_room_type_performance()"/>
                        <table class="report-table">
                            <thead>
                                <tr>
                                    <th>Physical Room Type</th>
                                    <th class="num">Occupancy %</th>
                                    <th class="num">ADR Value</th>
                                    <th class="num">RevPAR Value</th>
                                    <th class="num">Revenue Share %</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="rooms" t-as="r">
                                    <td><span t-esc="r.get('room_type', 'Unknown')"/></td>
                                    <td class="num"><span t-esc="'%.2f' % (r.get('occ_pct') or 0.0)"/>%</td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % (r.get('adr') or 0.0)"/>
                                    </td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % (r.get('revpar') or 0.0)"/>
                                    </td>
                                    <td class="num"><span t-esc="'%.2f' % (r.get('revenue_share') or 0.0)"/>%</td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Two Column Operational Details (Events & Maintenance SLAs) -->
                        <div class="details-columns row">
                            <div class="col-6">
                                <div class="column-box">
                                    <h3>Weekly Operational Highlights</h3>
                                    <ul class="bullet-list">
                                        <li><strong>Rate Yielding:</strong> Walk-in rates adjusted upward dynamically for weekend occupancy spikes.</li>
                                        <li><strong>VIP Inflows:</strong> Seamless VIP guest arrivals handled with executive services.</li>
                                        <li><strong>Group Inquiries:</strong> Direct corporate booking rates closed above target objectives.</li>
                                    </ul>
                                </div>
                            </div>

                            <div class="col-6">
                                <div class="column-box">
                                    <h3>Maintenance and Housekeeping SLAs</h3>
                                    <ul class="bullet-list">
                                        <li><strong>Turnaround Time:</strong> Average guest room make-ready completed inside 30 mins.</li>
                                        <li><strong>Work Orders:</strong> 95% of routine engineering items addressed within SLA window.</li>
                                        <li><strong>Quality Inspections:</strong> Housekeeping scores maintained at high-luxury benchmarks.</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <!-- Manager/Auditor Sign-off -->
                        <footer class="report-footer">
                            <div>Report compiled automatically from PMS records. System classification: Confidential.</div>
                            <div class="signature-container">
                                <div class="signature-line">Hotel Manager Signature</div>
                                <div class="signature-line">Operations Director Approval</div>
                            </div>
                        </footer>
                    </main>
                </t>
            </t>
        </t>
    </template>

    <template id="report_monthly_owner_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <style type="text/css"><![CDATA[
                    /* Base Styles and Typography */
                    body {
                        font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Arial, sans-serif;
                        color: #2E2E2E !important; /* Charcoal */
                        font-size: 9.5pt;
                        line-height: 1.4;
                    }

                    /* Header styling */
                    .report-header {
                        border-bottom: 2px solid #C7A447; /* Brand Gold */
                        padding-bottom: 10px;
                        margin-bottom: 25px;
                        display: flex;
                        justify-content: space-between;
                        align-items: flex-end;
                    }
                    .brand-section h1 {
                        font-size: 20pt;
                        font-weight: 700;
                        color: #2E2E2E;
                        margin: 0;
                        text-transform: uppercase;
                        letter-spacing: 0.02em;
                    }
                    .brand-section h1 span {
                        color: #C7A447; /* Gold Accent */
                    }
                    .brand-section p {
                        margin: 2px 0 0 0;
