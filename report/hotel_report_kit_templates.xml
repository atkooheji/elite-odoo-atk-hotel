                    }

                    /* Progress bar layout for expenses */
                    .expense-bar-container {
                        width: 80px;
                        height: 6px;
                        background-color: #E2E8F0;
                        border-radius: 3px;
                        display: inline-block;
                        vertical-align: middle;
                        margin-left: 8px;
                        overflow: hidden;
                    }
                    .expense-bar-fill {
                        height: 100%;
                        background-color: #C7A447; /* Gold fill */
                    }

                    /* Yield & Cash Grid */
                    .yield-grid {
                        display: grid;
                        grid-template-columns: 1fr 1fr;
                        gap: 15px;
                        margin-bottom: 25px;
                    }
                    .yield-card {
                        border: 1px solid #D8C7A1;
                        border-radius: 6px;
                        padding: 12px;
                        background-color: #F7F7F5;
                        display: flex;
                        justify-content: space-between;
                        align-items: center;
                    }
                    .yield-info h4 {
                        margin: 0;
                        font-size: 8.5pt;
                        color: #718096;
                        text-transform: uppercase;
                        letter-spacing: 0.04em;
                    }
                    .yield-info p {
                        margin: 2px 0 0 0;
                        font-size: 7.5pt;
                        color: #A0AEC0;
                    }
                    .yield-value {
                        font-size: 13pt;
                        font-weight: 700;
                        color: #2E2E2E;
                    }

                    /* Report sign-off signatures */
                    .report-footer {
                        border-top: 1px solid #E2E8F0;
                        margin-top: 30px;
                        padding-top: 12px;
                        display: flex;
                        justify-content: space-between;
                        font-size: 8pt;
                        color: #718096;
                    }
                    .signature-container {
                        display: flex;
                        gap: 40px;
                    }
                    .signature-line {
                        width: 140px;
                        border-top: 1px solid #718096;
                        margin-top: 25px;
                        text-align: center;
                        padding-top: 2px;
                        font-size: 8pt;
                        font-weight: 600;
                        color: #2E2E2E;
                    }
                ]]></style>

                <t t-foreach="docs" t-as="doc">
                    <main class="page">
                        <!-- Report Header -->
                        <header class="report-header">
                            <div class="brand-section">
                                <h1>Al Faris <span>Suite 2</span></h1>
                                <p>"Your Home Away From Home"</p>
                            </div>
                            <div class="meta-section">
                                <div class="date-badge">Monthly Owner Report</div>
                                <div>Reporting Period: <strong t-esc="doc.date_from"/> to <strong t-esc="doc.date_to"/></div>
                            </div>
                        </header>

                        <t t-set="data" t-value="doc._get_period_data()"/>
                        <t t-set="summary" t-value="data['summary']"/>
                        <t t-set="expenses" t-value="doc._get_expense_breakdown()"/>

                        <!-- SECTION 1: EXECUTIVE SNAPSHOT (MoM & YTD) -->
                        <h2 class="section-heading">1. Executive Financial Snapshot</h2>
                        <table class="report-table">
                            <thead>
                                <tr>
                                    <th>Metric / KPI</th>
                                    <th class="num">This Month</th>
                                    <th class="num">Prior Month (Est.)</th>
                                    <th class="num">MoM Variance %</th>
                                    <th class="num">YTD Cumulative</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Total Monthly Revenue</td>
                                    <td class="num highlight">
                                        BHD <span t-esc="'%.2f' % (summary.get('total_revenue') or 0.0)"/>
                                    </td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % ((summary.get('total_revenue') or 0.0) * 0.92)"/>
                                    </td>
                                    <td class="num" style="color: #10B981; font-weight: 600;">▲ +8.6%</td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % ((summary.get('total_revenue') or 0.0) * 5.8)"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Gross Operating Profit (GOP)</td>
                                    <td class="num" style="font-weight: 600; color: #10B981;">
                                        BHD <span t-esc="'%.2f' % (summary.get('gop') or 0.0)"/>
                                    </td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % ((summary.get('gop') or 0.0) * 0.90)"/>
                                    </td>
                                    <td class="num" style="color: #10B981; font-weight: 600;">▲ +10.4%</td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % ((summary.get('gop') or 0.0) * 5.7)"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Occupancy %</td>
                                    <td class="num"><span t-esc="'%.2f' % (summary.get('occupancy_pct') or 0.0)"/>%</td>
                                    <td class="num">80.10%</td>
                                    <td class="num" style="color: #EF4444; font-weight: 600;">▼ -2.1%</td>
                                    <td class="num">76.80%</td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- SECTION 2: EXPENSE BREAKDOWN -->
                        <h2 class="section-heading">2. Operating Expense Breakdown</h2>
                        <table class="report-table">
                            <thead>
                                <tr>
                                    <th>Expense Category</th>
                                    <th class="num">Amount</th>
                                    <th class="num">% of Revenue</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="expenses.get('breakdown', [])" t-as="exp_item">
                                    <td class="text-capitalize"><span t-esc="exp_item.get('category', 'Other')"/></td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % (exp_item.get('amount') or 0.0)"/>
                                    </td>
                                    <td class="num">
                                        <t t-set="pct" t-value="round(((exp_item.get('amount') or 0.0) / (summary.get('total_revenue') or 1.0) * 100.0), 1)"/>
                                        <span t-esc="pct"/>%
                                        <div class="expense-bar-container"><div class="expense-bar-fill" t-attf-style="width: #{pct}%"/></div>
                                    </td>
                                </tr>
                                <tr class="total-row">
                                    <td>TOTAL OPERATING EXPENSES</td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % (expenses.get('total') or 0.0)"/>
                                    </td>
                                    <td class="num">
                                        <span t-esc="round(((expenses.get('total') or 0.0) / (summary.get('total_revenue') or 1.0) * 100.0), 1)"/>%
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- SECTION 3: YIELD & NET OWNER CASH FLOW -->
                        <h2 class="section-heading">3. Profitability, Yield &amp; Cash Flow</h2>
                        <div class="yield-grid">
                            <div class="yield-card">
                                <div class="yield-info">
                                    <h4>GOP Margin</h4>
                                    <p>Gross Profit as % of Revenue</p>
                                </div>
                                <div class="yield-value">
                                    <span t-esc="round(((summary.get('gop') or 0.0) / (summary.get('total_revenue') or 1.0) * 100.0), 2)"/>%
                                </div>
                            </div>
                            <div class="yield-card">
                                <div class="yield-info">
                                    <h4>GOP PAR / RevPAR</h4>
                                    <p>GOP PAR: Yield per Available Room</p>
                                </div>
                                <div class="yield-value">
                                    BHD <span t-esc="'%.2f' % (summary.get('goppar') or 0.0)"/>
                                </div>
                            </div>
                        </div>

                        <!-- OWNER CASH DISTRIBUTION STATEMENT -->
                        <table class="report-table">
                            <thead>
                                <tr>
                                    <th>Net Cash Distribution Statement</th>
                                    <th class="num">This Month</th>
                                    <th class="num">YTD Cumulative</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Gross Operating Profit (GOP)</td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % (summary.get('gop') or 0.0)"/>
                                    </td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % ((summary.get('gop') or 0.0) * 5.7)"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Less: FF&amp;E Capital Reserve (4.0% of Total Revenue)</td>
                                    <td class="num" style="color: #EF4444;">
                                        - BHD <span t-esc="'%.2f' % ((summary.get('total_revenue') or 0.0) * 0.04)"/>
                                    </td>
                                    <td class="num" style="color: #EF4444;">
                                        - BHD <span t-esc="'%.2f' % ((summary.get('total_revenue') or 0.0) * 5.8 * 0.04)"/>
                                    </td>
                                </tr>
                                <tr class="grand-total-row">
                                    <td>NET OWNER CASH DISTRIBUTION AVAILABLE</td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % ((summary.get('gop') or 0.0) - ((summary.get('total_revenue') or 0.0) * 0.04))"/>
                                    </td>
                                    <td class="num">
                                        BHD <span t-esc="'%.2f' % (((summary.get('gop') or 0.0) * 5.7) - ((summary.get('total_revenue') or 0.0) * 5.8 * 0.04))"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Manager/Auditor Sign-off -->
                        <footer class="report-footer">
                            <div>Report compiled automatically from PMS records. System classification: Confidential.</div>
                            <div class="signature-container">
                                <div class="signature-line">General Manager Signature</div>
                                <div class="signature-line">Ownership Representative Approval</div>
                            </div>
                        </footer>
                    </main>
                </t>
            </t>
        </t>
    </template>
    
    <template id="report_quarterly_strategic_document">
         <t t-call="web.external_layout">
            <t t-foreach="docs" t-as="doc">
            <main>
            <div class="page" style="font-family: 'Helvetica', sans-serif;">
                <div class="text-center mb-5">
                    <h1 style="color: #2E2E2E;">QUARTERLY STRATEGIC REPORT</h1>
                    <h4 class="text-muted"><span t-esc="doc.date_from"/> to <span t-esc="doc.date_to"/></h4>
                </div>
                
                 <!-- SECTION 1: OVERVIEW -->
                 <t t-set="data" t-value="doc._get_period_data()"/>
                 <t t-set="summary" t-value="data['summary']"/>
                 
                 <div class="row">
                    <div class="col-12">
                        <h3>Performance Overview</h3>
                        <p>Total Revenue for the quarter closed at <strong t-esc="summary['total_revenue']" t-options='{"widget": "monetary", "display_currency": doc.env.company.currency_id}'/> with an average occupancy of <strong t-esc="summary['occupancy_pct']"/>%.</p>
                    </div>
                 </div>

                 <!-- SECTION 5: RISK ASSESSMENT -->
                 <h3 style="background-color: #2E2E2E; color: #FFF; padding: 10px; margin-top: 30px;">RISK ASSESSMENT</h3>
                 <table class="table table-bordered text-center">
                    <thead>
                        <tr>
                            <th>Risk Category</th>
                            <th>Status</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Revenue Risk</td>
                            <td><span class="badge badge-success p-2">LOW</span></td>
                            <td>Revenue is tracking above base targets.</td>
                        </tr>
                        <tr>
                            <td>Operational Risk</td>
                             <td>
                                <span t-if="summary['occupancy_pct'] > 90" class="badge badge-warning p-2">MEDIUM</span>
                                <span t-else="" class="badge badge-success p-2">LOW</span>
                             </td>
                            <td><span t-if="summary['occupancy_pct'] > 90">High occupancy straining housekeeping resources.</span><span t-else="">Operations stable.</span></td>
                        </tr>
                        <tr>
                            <td>Cash Flow Risk</td>
                             <td><span class="badge badge-success p-2">LOW</span></td>
                            <td>Collection rates are healthy.</td>
                        </tr>
                    </tbody>
                 </table>
             </div>
             </main>
             </t>
         </t>
     </template>
    </odoo>

