<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_hotel_intelligence_kit" model="ir.actions.report">
        <field name="name">Al Faris Intelligence Kit</field>
        <field name="model">hotel.report.kit.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">atk_hotel.report_intelligence_kit_template</field>
        <field name="report_file">atk_hotel.report_intelligence_kit_template</field>
        <field name="print_report_name">'Intelligence Kit - %s' % (object.report_type)</field>
        <field name="binding_model_id" ref="atk_hotel.model_hotel_report_kit_wizard"/>
        <field name="binding_type">report</field>
    </record>

