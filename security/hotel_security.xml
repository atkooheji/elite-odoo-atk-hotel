<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_hotel_management" model="ir.module.category">
        <field name="name">Hotel Management</field>
        <field name="description">Helps you manage hotel rooms, bookings, and housekeeping.</field>
        <field name="sequence">10</field>
    </record>

    <record id="privilege_hotel_management" model="res.groups.privilege">
        <field name="name">Hotel Management</field>
        <field name="category_id" ref="module_category_hotel_management"/>
    </record>

    <record id="group_hotel_user" model="res.groups">
        <field name="name">User (Receptionist)</field>
        <field name="privilege_id" ref="privilege_hotel_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_hotel_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_hotel_management"/>
        <field name="implied_ids" eval="[(4, ref('atk_hotel.group_hotel_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Multi-Company Rules -->
    <record id="hotel_room_comp_rule" model="ir.rule">
        <field name="name">Hotel Room Multi-Company</field>
        <field name="model_id" ref="model_hotel_room"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="hotel_booking_comp_rule" model="ir.rule">
        <field name="name">Hotel Booking Multi-Company</field>
        <field name="model_id" ref="model_hotel_book_history"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
