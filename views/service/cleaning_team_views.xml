<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--        Cleaning Team Tree View-->
    <record id="cleaning_team_view_tree" model="ir.ui.view">
        <field name="name">cleaning.team.view.tree</field>
        <field name="model">cleaning.team</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="team_head_id" />
            </list>
        </field>
    </record>
    <!--        Cleaning Team Form View-->
    <record id="cleaning_team_view_form" model="ir.ui.view">
        <field name="name">cleaning.team.view.form</field>
        <field name="model">cleaning.team</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group col="4">
                        <field name="name" />
                        <field name="team_head_id" />
                    </group>
                    <notebook>
                        <page string="Members">
                            <field name="member_ids">
                                <kanban>
                                    <field name="name" />
                                    <field name="job_title" />
                                    <field name="work_phone" />
                                    <field name="image_1920" />
                                    <templates>
                                        <t t-name="card">
                                            <div t-attf-class="oe_kanban_global_click">
                                                <div class="oe_kanban_image">
                                                    <img t-attf-src="/web/image/hotel.cleaning.team/{{record.id.raw_value}}/image_1920" alt="Avatar" class="o_image_64_contain" />
                                                </div>
                                                <div class="oe_kanban_details ml8">
                                                    <div class="oe_kanban_record_heading">
                                                        <strong>
                                                            <field name="name" />
                                                            <br />
                                                            <field name="job_title" />
                                                            <br />
                                                            <field name="work_phone" />
                                                        </strong>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!--    Cleaning Team Menu Action-->
    <record id="cleaning_team_action" model="ir.actions.act_window">
        <field name="name">Cleaning Team</field>
        <field name="res_model">cleaning.team</field>        <field name="view_mode">list,form</field>
        <field name="context">{}</field>

    </record>

    <menuitem id="hotel_config_menu" name="Cleaning" parent="menu_hotel_root" sequence="180" groups="atk_hotel.cleaning_team_group_user" />
    <!--Menu Cleaning-->
    <menuitem id="hotel_config_menu_cleaning" name="Cleaning" parent="hotel_config_menu" sequence="186" groups="atk_hotel.cleaning_team_group_user" />
    <!--Menu Cleaning Team-->
    <menuitem id="cleaning_team_menu" name="Cleaning Team" parent="hotel_config_menu_cleaning" action="cleaning_team_action" groups="atk_hotel.cleaning_team_group_head" />
</odoo>
