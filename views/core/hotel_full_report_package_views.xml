<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_atk_hotel_full_report_package_wizard_form" model="ir.ui.view">
        <field name="name">ism.hotel.full.report.package.wizard.form</field>
        <field name="model">ism.hotel.full.report.package.wizard</field>
        <field name="arch" type="xml">
            <form string="Print Full Hotel Report Package">
                <group>
                    <group>
                        <field name="date"/>
                        <field name="company_id"/>
                        <field name="booking_id"/>
                        <field name="room_id"/>
                    </group>
                    <group>
                        <field name="hotel_dashboard_id"/>
                        <field name="mis_eod_id"/>
                    </group>
                </group>
                <group string="Cleaning Requests">
                    <field name="cleaning_request_ids" widget="many2many_tags"/>
                </group>
                <group string="Reports to Include" col="2">
                    <field name="include_grc"/>
                    <field name="include_booking_summary"/>
                    <field name="include_room_summary"/>
                    <field name="include_cleaning"/>
                    <field name="include_mis_dashboard"/>
                    <field name="include_daily_status"/>
                    <field name="include_eod"/>
                </group>
                <footer>
                    <button name="action_print_full_package" string="Print Package" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_atk_hotel_full_report_package_wizard" model="ir.actions.act_window">
        <field name="name">Print Full Hotel Report Package</field>
        <field name="res_model">ism.hotel.full.report.package.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_atk_hotel_full_report_package_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{'default_booking_id': active_id}</field>
    </record>

    <record id="view_hotel_book_history_form_full_package_inherit" model="ir.ui.view">
        <field name="name">hotel.book.history.form.full.package.inherit</field>
        <field name="model">hotel.book.history</field>
        <field name="inherit_id" ref="atk_hotel.view_hotel_book_history_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(action_atk_hotel_full_report_package_wizard)d" string="Print Full Package" type="action" class="btn-primary"/>
            </xpath>
        </field>
    </record>
</odoo>
