<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hotel_mis_snapshot_tree" model="ir.ui.view">
        <field name="name">hotel.mis.snapshot.tree</field>
        <field name="model">hotel.mis.snapshot</field>
        <field name="arch" type="xml">
            <list string="Daily MIS Snapshot" create="false" edit="false" default_order="snapshot_date desc">
                <field name="snapshot_date"/>
                <field name="total_rooms"/>
                <field name="occupied_rooms"/>
                <field name="available_rooms"/>
                <field name="maintenance_rooms"/>
                <field name="occupancy_rate" string="Occupancy %"/>
                <field name="bookings_count"/>
                <field name="arrivals"/>
                <field name="departures"/>
                <field name="cancellations"/>
                <field name="revenue_amount" widget="monetary"/>
                <field name="avg_daily_rate" widget="monetary"/>
                <field name="avg_stay_length"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_hotel_mis_snapshot_graph" model="ir.ui.view">
        <field name="name">hotel.mis.snapshot.graph</field>
        <field name="model">hotel.mis.snapshot</field>
        <field name="arch" type="xml">
            <graph string="Snapshot Trend" type="line">
                <field name="snapshot_date" type="row"/>
                <field name="occupancy_rate" type="measure" string="Occupancy %"/>
                <field name="revenue_amount" type="measure" string="Revenue"/>
            </graph>
        </field>
    </record>

    <record id="view_hotel_mis_snapshot_pivot" model="ir.ui.view">
        <field name="name">hotel.mis.snapshot.pivot</field>
        <field name="model">hotel.mis.snapshot</field>
        <field name="arch" type="xml">
            <pivot string="Snapshot Pivot">
                <field name="snapshot_date" type="row" interval="day"/>
                <field name="occupancy_rate" type="measure" string="Occupancy %"/>
                <field name="revenue_amount" type="measure" string="Revenue"/>
                <field name="bookings_count" type="measure" string="Bookings"/>
            </pivot>
        </field>
    </record>

    <record id="action_hotel_mis_snapshot" model="ir.actions.act_window">
        <field name="name">Daily Snapshot</field>
        <field name="res_model">hotel.mis.snapshot</field>
        <field name="view_mode">list,graph,pivot</field>
        <field name="view_id" ref="view_hotel_mis_snapshot_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Generate bookings to populate the daily snapshot.</p>
            <p>Analyse occupancy, arrivals, departures, and revenue day-by-day.</p>
        </field>
    </record>

    <record id="action_hotel_mis_booking_matrix" model="ir.actions.act_window">
        <field name="name">Occupancy Matrix</field>
        <field name="res_model">hotel.book.history</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="view_id" ref="view_hotel_book_history_pivot"/>
    </record>

    <record id="view_sale_order_hotel_mis_pivot" model="ir.ui.view">
        <field name="name">sale.order.hotel.mis.pivot</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <pivot string="Revenue Analytics">
                <field name="date_order" type="col" interval="month"/>
                <field name="partner_id" type="row" string="Guest"/>
                <field name="amount_total" type="measure" string="Revenue"/>
            </pivot>
        </field>
    </record>

    <record id="view_sale_order_hotel_mis_graph" model="ir.ui.view">
        <field name="name">sale.order.hotel.mis.graph</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <graph string="Revenue Trend" type="bar">
                <field name="date_order" type="row" interval="month"/>
                <field name="amount_total" type="measure" string="Revenue"/>
            </graph>
        </field>
    </record>

    <record id="action_hotel_mis_revenue_analysis" model="ir.actions.act_window">
        <field name="name">Revenue Analysis</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="views" eval="[(ref('view_sale_order_hotel_mis_pivot'), 'pivot'), (ref('view_sale_order_hotel_mis_graph'), 'graph')]"/>
        <field name="domain">[("state", "in", ["sale", "done"])]</field>
    </record>

    <record id="view_hotel_mis_report_wizard_form" model="ir.ui.view">
        <field name="name">hotel.mis.report.wizard.form</field>
        <field name="model">hotel.mis.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Hotel End of Day">
                <sheet>
                    <group string="Filters" col="4">
                        <group string="Period" col="2">
                            <field name="period_preset"/>
                            <field name="date_from" required="1" readonly="period_preset != 'custom'"/>
                            <field name="date_to" required="1" readonly="period_preset != 'custom'"/>
                        </group>
                        <group string="Options" col="2">
                            <field name="grouping_mode"/>
                        </group>
                    </group>
                    <group string="Audience" col="2">
                        <field name="report_audience" widget="radio"/>
                    </group>
                    <group string="Appendices" col="2">
                        <field name="include_reservation_appendix"/>
                        <field name="include_revenue_appendix"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_gm_eod_pdf" type="object" string="GM PDF" class="btn-primary"/>
                    <button name="action_print_gm_eod_html" type="object" string="GM HTML" class="btn-secondary"/>
                    <button name="action_print_finance_eod_pdf" type="object" string="Finance PDF" class="btn-primary"/>
                    <button name="action_print_finance_eod_html" type="object" string="Finance HTML" class="btn-secondary"/>
                    <button string="Cancel" class="btn-link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hotel_mis_report_wizard" model="ir.actions.act_window">
        <field name="name">End of Day Report</field>
        <field name="res_model">hotel.mis.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_hotel_mis_report_wizard_form"/>
    </record>

    <record id="action_hotel_cleaning_requests_report" model="ir.actions.act_window">
        <field name="name">Cleaning Requests</field>
        <field name="res_model">cleaning.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
    </record>

    <menuitem id="menu_hotel_reports_root" name="Reports" parent="menu_hotel_root" sequence="40"/>

    <menuitem id="menu_hotel_reports_snapshot" parent="menu_hotel_reports_root" action="action_hotel_mis_snapshot" sequence="5"/>
    <menuitem id="menu_hotel_reports_booking" parent="menu_hotel_reports_root" action="action_hotel_mis_booking_matrix" sequence="10"/>
    <menuitem id="menu_hotel_reports_revenue" parent="menu_hotel_reports_root" action="action_hotel_mis_revenue_analysis" sequence="15"/>
    <menuitem id="menu_hotel_reports_eod" parent="menu_hotel_reports_root" action="action_hotel_mis_report_wizard" sequence="20"/>
    <menuitem id="menu_hotel_reports_daily_status" parent="menu_hotel_reports_root" action="action_hotel_daily_status_report_wizard" sequence="25"/>
    <menuitem id="menu_hotel_reports_cleaning" parent="menu_hotel_reports_root" action="action_hotel_cleaning_requests_report" sequence="30"/>
</odoo>
