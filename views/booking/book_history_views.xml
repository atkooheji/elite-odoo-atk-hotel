<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================== TREE VIEW ================== -->
    <record id="view_hotel_book_history_tree" model="ir.ui.view">
        <field name="name">hotel.book.history.tree</field>
        <field name="model">hotel.book.history</field>
        <field name="arch" type="xml">
            <list string="Reservations" delete="false" default_order="check_in asc" multi_edit="1">
                <field name="name" string="Ref" />
                <field name="partner_id" string="Guest" />
                <field name="booking_source_id" string="Source" />
                <!--                <field name="ota_source_id" string="OTA Source"/>-->
                <field name="room_id" string="Room" />
                <field name="check_in" options="{'format': 'dd MMM yyyy'}" />
                <field name="check_out" options="{'format': 'dd MMM yyyy'}" />
                <field name="duration" string="Nights" />
                <field name="total_amount" widget="monetary" />
                <field name="state" widget="badge" decoration-info="state == 'confirmed'" decoration-warning="state == 'checked_in'" decoration-success="state == 'checked_out'" decoration-danger="state == 'cancelled'" />
                <field name="payment_status" />
                <button name="action_checkin" string="CallCheck In" type="object" icon="fa-sign-in" invisible="state != 'confirmed'" class="btn-primary" />
                <button name="action_checkout" string="CallCheck Out" type="object" icon="fa-sign-out" invisible="state != 'checked_in'" class="btn-success" />
            </list>
        </field>
    </record>
    <!-- ================== FORM VIEW (if not exists, minimal) ================== -->
    <record id="view_hotel_book_history_form" model="ir.ui.view">
        <field name="name">hotel.book.history.form</field>
        <field name="model">hotel.book.history</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary" invisible="state != 'draft'" />
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" groups="atk_hotel.group_hotel_manager" invisible="state != 'to_approve'" />
                    <button name="action_checkin" string="Check In" type="object" class="btn-success" invisible="state != 'confirmed'" />
                    <button name="action_checkout" string="Check Out" type="object" class="btn-info" invisible="state != 'checked_in'" />
                    <button name="%(action_hotel_transfer_room_wizard)d" string="Transfer Room" type="action" class="btn-secondary" invisible="state not in ('confirmed', 'checked_in')" />
                    <button name="action_cancel" string="Cancel" type="object" class="btn-danger" invisible="state in ['checked_out','cancelled']" />
                    <button name="action_print_grc" string="Print GRC" type="object" class="btn-secondary" />
                    <button name="action_print_mis_summary" string="Print Summary" type="object" class="btn-secondary" />
                    <button name="action_open_guest_form" string="Create Guest" type="object" class="btn-secondary" invisible="partner_id != False" />
                    <button name="action_create_loyalty_card" string="Create Loyalty Card" type="object" class="btn-secondary" />
                    <button name="action_refund_payment_al" string="Refund Payment" type="object" class="btn-warning" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,checked_in,checked_out,cancelled" />
                </header>
                <sheet>
                    <field name="payment_status" widget="web_ribbon" />
                    <!--                    <div name="button_box" class="oe_button_box">-->
                    <!--                        &lt;!&ndash; Deposit Payment Smart Button &ndash;&gt;-->
                    <!--                        <button type="object"-->
                    <!--                            name="action_view_deposit_payment"-->
                    <!--                            class="oe_stat_button"-->
                    <!--                            icon="fa-money">-->
                    <!--                            <field string="Deposit Payment" name="deposit_payment_id" widget="statinfo"/>-->
                    <!--                        </button>-->
                    <!--                        &lt;!&ndash; Sale Order Smart Button &ndash;&gt;-->
                    <!--                        <button type="object"-->
                    <!--                            name="action_view_sale_order"-->
                    <!--                            class="oe_stat_button"-->
                    <!--                            icon="fa-shopping-cart">-->
                    <!--                            <field string="Sale Order" name="sale_order_id" widget="statinfo"/>-->
                    <!--                        </button>-->
                    <!--                    </div>-->
                    <group>
                        <group>
                            <field name="name" readonly="state == 'checked_out'" />
                            <field name="partner_id" readonly="state == 'checked_out'" context="{'default_is_hotel_customer': True}" options="{'no_create_edit': True}" />
                            <field name="booking_source_id" readonly="state == 'checked_out'" />
                            <field name="check_in" options="{'format': 'dd/MM/yyyy'}" readonly="state == 'checked_out'" />
                            <field name="check_out" options="{'format': 'dd/MM/yyyy'}" readonly="state == 'checked_out'" />
                            <field name="duration" readonly="state == 'checked_out'" />
                            <field name="show_price_split" readonly="state == 'checked_out'" />
                            <field name="total_amount" readonly="state == 'checked_out'" />
                            <field name="payment_status" invisible="1" />
                        </group>
                        <!--                    <group string="Deposit">-->
                        <!--                        <field name="deposit_amount"/>-->
                        <!--                        <field name="deposit_paid" readonly="1"/>-->
                        <!--                        <field name="deposit_payment_id" readonly="1"/>-->
                        <!--                    </group>-->
                        <group>
                            <field name="room_id" readonly="state == 'checked_out'" />
                            <field name="sale_order_id" readonly="1" />
                            <field name="has_sale_order" invisible="1" />
                            <field name="total_adults" readonly="state == 'checked_out'" />
                            <field name="total_children" readonly="state == 'checked_out'" />
                            <field name="total_infants" readonly="state == 'checked_out'" />
                            <field name="deposit_amount" readonly="state == 'checked_out'" />
                            <field name="deposit_paid" readonly="1" />
                            <field name="deposit_payment_id" readonly="1" />
                        </group>
                        <group string="Guest Identity">
                            <field name="passport_no" />
                            <field name="passport_place" />
                            <field name="passport_expiry" />
                        </group>
                        <group string="Visa Information">
                            <field name="visa_no" />
                            <field name="visa_place" />
                            <field name="visa_expiry" />
                            <field name="visa_type" />
                        </group>
                        <group string="Travel Info">
                            <field name="corporate" />
                            <field name="arrived_from" />
                            <field name="proceed_to" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Daily Breakdown">
                            <field name="daily_line_ids" context="{'default_booking_id': id}" readonly="state == 'checked_out'">
                                <list editable="bottom">
                                    <field name="date" />
                                    <field name="amount" />
                                </list>
                                <form>
                                    <group>
                                        <field name="date" />
                                        <field name="amount" />
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Additional Bills">
                            <field name="additional_product_line_ids" nolabel="1" readonly="state == 'checked_out'">
                                <list editable="bottom">
                                    <field name="product_id" />
                                    <field name="name" />
                                    <field name="quantity" />
                                    <field name="price_unit" />
                                    <field name="subtotal" readonly="1" />
                                </list>
                                <form>
                                    <group>
                                        <field name="product_id" />
                                        <field name="name" />
                                        <field name="quantity" />
                                        <field name="price_unit" />
                                        <field name="subtotal" readonly="1" />
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Audit &amp; MIS" groups="atk_hotel.group_hotel_manager">
                            <group>
                                <group string="Approval Tracking">
                                    <field name="approver_id" />
                                    <field name="approved_date" />
                                    <field name="is_complimentary" />
                                    <field name="is_house_use" />
                                </group>
                                <group string="SLA Performance">
                                    <field name="arrival_date" />
                                    <field name="checkin_delay" widget="float_time" />
                                    <field name="actual_checkout_date" />
                                    <field name="stay_duration_actual" widget="float_time" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                    <group string="Digital Signatures" colspan="2">
                        <group>
                            <h4>Customer Signature</h4>
                            <field name="customer_signature" widget="signature" class="oe_inline" />
                            <field name="customer_signed_by" readonly="1" />
                            <field name="customer_signed_date" readonly="1" />
                        </group>
                        <group>
                            <h4>Receptionist Signature</h4>
                            <field name="receptionist_signature" widget="signature" class="oe_inline" />
                            <field name="receptionist_signed_by" readonly="1" />
                            <field name="receptionist_signed_date" readonly="1" />
                        </group>
                    </group>
                </sheet>
                <chatter/>
                <!-- <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div> -->
            </form>
        </field>
    </record>
    <!-- ================== SEARCH VIEW ================== -->
    <record id="view_hotel_book_history_search" model="ir.ui.view">
        <field name="name">hotel.book.history.search</field>
        <field name="model">hotel.book.history</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="room_id"/>
                <filter name="confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="checked_in" string="Checked In" domain="[('state', '=', 'checked_in')]"/>
                <group>
                    <filter name="group_by_room" string="Room" context="{'group_by': 'room_id'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
    <!-- ================== GRAPH VIEW ================== -->
    <record id="view_hotel_book_history_graph" model="ir.ui.view">
        <field name="name">hotel.book.history.graph</field>
        <field name="model">hotel.book.history</field>
        <field name="arch" type="xml">
            <graph string="Revenue by Room Type" type="bar">
                <field name="room_type_id" type="row" />
                <field name="total_amount" type="measure" />
            </graph>
        </field>
    </record>
    <!-- ================== PIVOT VIEW ================== -->
    <record id="view_hotel_book_history_pivot" model="ir.ui.view">
        <field name="name">hotel.book.history.pivot</field>
        <field name="model">hotel.book.history</field>
        <field name="arch" type="xml">
            <pivot string="Occupancy Analysis">
                <field name="check_in" type="col" interval="month" />
                <field name="room_type_id" type="row" />
                <field name="duration_days_decimal" string="Nights" type="measure" />
            </pivot>
        </field>
    </record>
    <!-- ================== CALENDAR VIEW ================== -->
    <record id="view_hotel_book_history_calendar" model="ir.ui.view">
        <field name="name">hotel.book.history.calendar</field>
        <field name="model">hotel.book.history</field>
        <field name="arch" type="xml">
            <calendar string="Bookings Calendar" date_start="check_in" date_stop="check_out" color="partner_id">
                <field name="name" />
                <field name="partner_id" />
                <field name="room_id" />
            </calendar>
        </field>
    </record>
    <!-- ================== KANBAN VIEW ================== -->
    <record id="view_hotel_book_history_kanban" model="ir.ui.view">
        <field name="name">hotel.book.history.kanban</field>
        <field name="model">hotel.book.history</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name" />
                <field name="partner_id" />
                <field name="booking_source_id" />
                <!-- <field name="ota_source_id" /> -->
                <field name="room_id" />
                <field name="check_in" />
                <field name="check_out" />
                <field name="total_amount" />
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="row">
                                <div class="col-12">
                                    <strong>
                                        <field name="name" />
                                    </strong>
                                </div>
                                <div class="col-12 text-muted">
                                    <field name="partner_id" />
                                </div>
                                <t t-if="record.booking_source_id.raw_value">
                                    <div class="col-12 text-muted">
                                        <i class="fa fa-map-signs" title="Booking Source" />
                                        <field name="booking_source_id" />
                                    </div>
                                </t>
                                <!-- <t t-if="record.ota_source_id.raw_value">
                                    <div class="col-12 text-muted">
                                        <i class="fa fa-globe" title="OTA Source" />
                                        <field name="ota_source_id" />
                                    </div>
                                </t> -->
                                <div class="col-12">
                                    <span>Room:</span>
                                    <field name="room_id" />
                                </div>
                                <div class="col-12 text-muted">
                                    <i class="fa fa-calendar" title="Check-in / Check-out" />
                                    <field name="check_in" />
                                    -
                                    <field name="check_out" />
                                </div>
                                <div class="col-12 mt-2">
                                    <span class="badge bg-success">
                                        ??
                                        <field name="total_amount" />
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!-- ================== MAIN ACTION ================== -->
    <record id="action_hotel_book_history_all" model="ir.actions.act_window">
        <field name="name">Reservations</field>        <field name="res_model">hotel.book.history</field>
        <field name="view_mode">list,form,graph,pivot,calendar,kanban</field>
        <!--        <field name="search_view_id" ref="view_hotel_book_history_search"/>-->
        <!--        <field name="context">{'search_default_filter_active': 1}</field>-->
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first booking to manage guest stays.</p>
            <p>Track check-ins, check-outs, revenue, and room assignments.</p>
        </field>
    </record>
    <!-- ================== MENU ================== -->

    <menuitem id="menu_hotel_reservations" name="Book History" parent="menu_hotel_root" action="action_hotel_book_history_all" sequence="2" />
</odoo>
