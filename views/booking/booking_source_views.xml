<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hotel_booking_source_tree" model="ir.ui.view">
        <field name="name">hotel.booking.source.tree</field>
        <field name="model">hotel.booking.source</field>
        <field name="arch" type="xml">
            <list string="Booking Sources" default_order="sequence, name">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_hotel_booking_source_form" model="ir.ui.view">
        <field name="name">hotel.booking.source.form</field>
        <field name="model">hotel.booking.source</field>
        <field name="arch" type="xml">
            <form string="Booking Source">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                        <field name="color" widget="color"/>
                    </group>
                    <group>
                        <field name="note" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hotel_booking_source" model="ir.actions.act_window">
        <field name="name">Booking Sources</field>        <field name="res_model">hotel.booking.source</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create booking sources to classify where reservations come from.
            </p>
        </field>
    </record>

    <menuitem id="menu_hotel_booking_source"
              name="Booking Sources"
              parent="menu_hotel_root"
              action="action_hotel_booking_source"
              sequence="6"/>
</odoo>
