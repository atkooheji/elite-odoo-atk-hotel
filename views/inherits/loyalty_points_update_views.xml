<odoo>
    <record id="loyalty_points_update_wizard_form" model="ir.ui.view">
        <field name="name">loyalty.points.update.wizard.form</field>
        <field name="model">loyalty.points.update.wizard</field>
        <field name="arch" type="xml">
            <form string="Update Loyalty Points">
                <group>
                    <field name="card_id" invisible="1"/>
                    <field name="points_change"/>
                    <field name="reason"/>
                </group>
                <footer>
                    <button name="action_update_points" string="Update Points" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_loyalty_points_update_wizard" model="ir.actions.act_window">
        <field name="name">Update Points</field>
        <field name="res_model">loyalty.points.update.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
