<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hotel_partner_form" model="ir.ui.view">
        <field name="name">res.partner.form.hotel</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form string="Hotel Guest">
                <sheet>
                    <group invisible="1">
                        <field name="name" />
                        <field name="is_hotel_customer" />
                    </group>
                    <group string="Guest Name" col="4">
                        <field name="first_name" required="1" />
                        <field name="middle_name" />
                        <field name="last_name" required="1" />
                    </group>
                    <group string="Contact Details" col="2">
                        <field name="phone" />
                        <field name="email" />
                        <field name="country_id" />
                    </group>
                    <group string="Address">
                        <field name="street" />
                        <field name="street2" />
                        <field name="city" />
                        <field name="state_id" />
                        <field name="zip" />
                    </group>
                    <group string="Preferences">
                        <field name="receives_daily_intel_report"/>
                        <field name="is_vip"/>
                        <field name="is_foreigner"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_partner_form_hotel_intel" model="ir.ui.view">
        <field name="name">res.partner.form.hotel.intel</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='internal_notes']" position="after">
                <page name="hotel_intel" string="Hotel Intelligence" groups="base.group_user">
                    <group string="Subscriptions">
                        <field name="receives_daily_intel_report"/>
                        <field name="is_hotel_customer" readonly="1"/>
                        <field name="is_vip"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
    <!-- Action for Hotel Customers -->
    <record id="action_hotel_customers" model="ir.actions.act_window">
        <field name="name">Hotel Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="views" eval="[(ref('base.view_partner_tree'), 'list'), (ref('atk_hotel.view_hotel_partner_form'), 'form')]" />
        <field name="context">{'default_is_hotel_customer': True}</field>
        <field name="domain">[('is_hotel_customer', '=', True)]</field>
    </record>
    <!-- Menu Item -->
    <menuitem id="menu_hotel_customers" name="Customers" parent="menu_hotel_root" action="action_hotel_customers" sequence="5" />
</odoo>
