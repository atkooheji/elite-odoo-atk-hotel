<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hotel_room_tree" model="ir.ui.view">
        <field name="name">hotel.room.tree</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <list multi_edit="1">
                <field name="name" />
                <field name="floor" />
                <field name="room_type" />
                <field name="company_id" optional="show"/>
                <field name="state" widget="badge" decoration-success="state == 'available'" decoration-warning="state == 'occupied'" decoration-danger="state == 'maintenance'" decoration-info="state == 'booked'" />
                <field name="cleaning_status" widget="badge" decoration-success="cleaning_status == 'clean'" decoration-danger="cleaning_status == 'dirty'" />
            </list>
        </field>
    </record>

    <record id="view_hotel_room_kanban" model="ir.ui.view">
        <field name="name">hotel.room.kanban</field>
        <field name="model">hotel.room</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" default_group_by="room_type" group_edit="false" group_delete="false" default_order="name">
                <field name="id" />
                <field name="name" />
                <field name="room_type" />
                <field name="state" />
                <field name="cleaning_status" />
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_card mb-3">
                            <div class="oe_kanban_content d-flex justify-content-between">
                                <div class="oe_kanban_title">
                                    <strong>
                                        <field name="name" />
                                    </strong>
                                </div>
                                <div class="oe_kanban_subtitle">
                                    <field name="state" widget="badge" decoration-success="state == 'available'" decoration-info="state == 'booked'" decoration-warning="state == 'occupied'" decoration-danger="state == 'maintenance'" title="Current status" />
                                </div>
                            </div>
                            <div class="oe_kanban_subtitle">
                                <field name="cleaning_status" widget="badge" decoration-success="cleaning_status == 'clean'" decoration-danger="cleaning_status == 'dirty'" title="Cleaning status" />
                            </div>
                            <hr />
                            <div class="oe_kanban_footer">
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <t t-if="record.state.raw_value == 'maintenance'">
                                            <button t-att-context="{'default_room_id': record.id}" name="action_available" string="Set to available" type="object" class="btn btn-success" />
                                        </t>
                                        <t t-if="record.state.raw_value == 'available'">
                                            <button t-att-context="{'default_room_id': record.id}" name="open_booking_form" string="Book" type="object" class="btn btn-info" />
                                        </t>
                                        <t t-if="record.state.raw_value == 'booked'">
                                            <button t-att-context="{'default_room_id': record.id}" name="open_checkin_form" string="Check In" type="object" class="btn btn-info" />
                                        </t>
                                        <t t-if="record.state.raw_value == 'occupied'">
                                            <button t-att-context="{'default_room_id': record.id}" name="open_checkout_form" string="Check Out" type="object" class="btn btn-info" />
                                        </t>
                                    </div>
                                    <div class="oe_kanban_bottom_right" invisible="state == 'booked'">
                                        <div class="o_dropdown_kanban dropdown">
                                            <a class="dropdown-toggle o-no-caret btn" role="button" data-bs-toggle="dropdown" data-bs-display="static" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                                <span class="fa fa-ellipsis-v" />
                                            </a>
                                            <div class="dropdown-menu" role="menu">
                                                <t t-if="record.state.raw_value == 'available'">
                                                    <a t-att-context="{'default_room_id': record.id}" name="action_maintenance" type="object" role="menuitem" class="dropdown-item">Set to Maintenance</a>
                                                </t>
                                                <t t-if="record.state.raw_value == 'maintenance'">
                                                    <a t-att-context="{'default_room_id': record.id}" name="action_available" type="object" role="menuitem" class="dropdown-item">Set to Available</a>
                                                </t>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_hotel_room_form" model="ir.ui.view">
        <field name="name">hotel.room.form</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_maintenance" string="Set to Maintenance" type="object" class="btn btn-danger" invisible="state == 'maintenance'" />
                    <button name="action_available" string="Set to Available" type="object" class="btn btn-success" invisible="state == 'available'" />
                    <button name="action_set_to_out_of_order" string="Out of Order" type="object" class="btn btn-warning" invisible="state == 'unavailable'"/>
                    <button name="action_print_room_summary" string="Print Summary" type="object" class="btn btn-secondary" />
                    <button name="action_create_maintenance_request" string="New Maintenance Request" type="object" class="btn btn-primary" />
                    <button name="action_schedule_inspection" string="Schedule Inspection" type="object" class="btn btn-secondary" />
                    <field name="state" widget="statusbar" statusbar_visible="available,occupied,maintenance,unavailable"/>
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="website_publish_button" type="object" class="oe_stat_button" icon="fa-globe">
                            <field name="is_published" widget="website_publish_button"/>
                        </button>
                        <button name="action_view_reservations" string="Bookings" type="object" class="oe_stat_button" icon="fa-money">
                            <field name="booking_count" string="Bookings" widget="statinfo" />
                        </button>
                        <button name="action_open_maintenance_requests" string="Maintenance" type="object" class="oe_stat_button" icon="fa-wrench">
                            <field name="maintenance_request_count" string="Maintenance" widget="statinfo" />
                        </button>
                        <button name="action_open_inspections" string="Inspections" type="object" class="oe_stat_button" icon="fa-search">
                            <field name="inspection_count" string="Inspections" widget="statinfo" />
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="floor" />
                            <field name="room_type_id" options="{'no_create': True}"/>
                            <field name="cleaning_status" widget="badge" decoration-success="cleaning_status == 'clean'" decoration-danger="cleaning_status == 'dirty'" />
                        </group>
                        <group>
                            <field name="rating_avg" widget="rating" readonly="1"/>
                            <field name="review_count" readonly="1"/>
                            <field name="state" invisible="1" />
                            <field name="out_of_order_reason" invisible="state != 'unavailable'" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Website" name="website_info">
                            <group>
                                <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_1920'}"/>
                                <field name="website_description" placeholder="Describe the room for website visitors..."/>
                            </group>
                        </page>

                        <page string="Maintenance Requests">
                            <field name="maintenance_request_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="name" />
                                    <field name="request_date" />
                                    <field name="maintenance_team_id" />
                                    <field name="stage_id" />
                                    <field name="company_id" invisible="1" />
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="name" />
                                            <field name="hotel_room_id" />
                                            <field name="maintenance_team_id" />
                                            <field name="request_date" />
                                            <field name="schedule_date" />
                                            <field name="stage_id" />
                                            <field name="description" />
                                            <field name="company_id" invisible="1" />
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Inspections">
                            <field name="inspection_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="name" />
                                    <field name="inspection_date" />
                                    <field name="inspector_id" />
                                    <field name="state" />
                                    <field name="maintenance_request_id" />
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="name" />
                                            <field name="room_id" />
                                            <field name="inspection_date" />
                                            <field name="inspector_id" />
                                            <field name="state" />
                                        </group>
                                        <group>
                                            <field name="notes" />
                                            <field name="follow_up_actions" />
                                            <field name="maintenance_request_id" />
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
                <!-- <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div> -->
            </form>
        </field>
    </record>

    <record id="view_hotel_room_search" model="ir.ui.view">
        <field name="name">hotel.room.search</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="room_type" />
                <group>
                    <filter name="available_rooms" string="Available Rooms Only" domain="[('state', '=', 'available')]" />
                    <filter name="dirty_rooms" string="Dirty" domain="[('cleaning_status', '=', 'dirty')]" />
                    <filter name="clean_rooms" string="Clean" domain="[('cleaning_status', '=', 'clean')]" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_hotel_room" model="ir.actions.act_window">
        <field name="name">Rooms</field>        <field name="res_model">hotel.room</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first room!</p>
        </field>
    </record>
</odoo>
