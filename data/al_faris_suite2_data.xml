<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="0">
    <function model="ir.config_parameter" name="set_param">
        <value eval="'hotel.api.company_name'"/>
        <value eval="'Al Faris Suite 2 W.L.L'"/>
    </function>

    <record id="room_type_penthouse_3bhk" model="hotel.room.type">
        <field name="company_id" ref="base.main_company"/>
        <field name="size_sqm">185</field>
        <field name="website_description">Signature penthouse suite with three bedrooms, expansive living space, dining area, equipped kitchen, and premium privacy for family or executive stays.</field>
    </record>
    <record id="room_type_superior_2bhk" model="hotel.room.type">
        <field name="company_id" ref="base.main_company"/>
        <field name="size_sqm">95</field>
        <field name="website_description">Comfortable two-bedroom suite with a separate living room, full kitchen, practical storage, and space for families or long-stay guests.</field>
    </record>
    <record id="room_type_premium_2bhk" model="hotel.room.type">
        <field name="company_id" ref="base.main_company"/>
        <field name="size_sqm">105</field>
        <field name="website_description">Premium two-bedroom suite with refined finishing, generous lounge space, full kitchen facilities, and a calm residential feel.</field>
    </record>
    <record id="room_type_deluxe_2bhk" model="hotel.room.type">
        <field name="company_id" ref="base.main_company"/>
        <field name="size_sqm">90</field>
        <field name="website_description">Deluxe two-bedroom suite designed for easy short or extended stays, with bright living space and essential apartment comforts.</field>
    </record>
    <record id="room_type_grand_2bhk" model="hotel.room.type">
        <field name="company_id" ref="base.main_company"/>
        <field name="size_sqm">115</field>
        <field name="website_description">Grand two-bedroom suite with larger living and dining areas, full kitchen, comfortable bedrooms, and a polished serviced-apartment experience.</field>
    </record>
    <record id="room_type_grand_1bhk" model="hotel.room.type">
        <field name="company_id" ref="base.main_company"/>
        <field name="size_sqm">70</field>
        <field name="website_description">Grand one-bedroom suite with a private bedroom, separate lounge, kitchen facilities, and the right balance of comfort and privacy.</field>
    </record>
    <record id="room_type_grand_studio" model="hotel.room.type">
        <field name="company_id" ref="base.main_company"/>
        <field name="size_sqm">45</field>
        <field name="website_description">Grand studio suite with a smart open-plan layout, kitchenette, work area, and everything needed for a comfortable stay in Juffair.</field>
    </record>

