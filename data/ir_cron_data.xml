<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
        <record id="ir_cron_daily_intelligence_kit" model="ir.cron">
            <field name="name">Hotel: Daily Intelligence Kit Dispatcher</field>
            <field name="model_id" ref="atk_hotel.model_hotel_report_kit_wizard"/>
            <field name="state">code</field>
            <field name="code">model.cron_send_daily_intelligence_kit()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).replace(hour=6, minute=0, second=0)"/>
            <field name="active" eval="True"/>
        </record>
        <record id="ir_cron_hotel_review_request" model="ir.cron">
            <field name="name">Hotel: Automated Guest Review Request</field>
            <field name="model_id" ref="atk_hotel.model_hotel_book_history"/>
            <field name="state">code</field>
            <field name="code">model.cron_request_reviews()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">4</field>
            <field name="interval_type">hours</field>
            <field name="nextcall" eval="(datetime.now() + timedelta(hours=4))"/>
            <field name="active" eval="True"/>
        </record>
</odoo>
